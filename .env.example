# Gateway HTTP server port
GATEWAY_PORT=3000

# Admin Console HTTP server port
ADMIN_PORT=3001

# Interface both HTTP servers bind to. Defaults to all interfaces; override to
# 127.0.0.1 for a loopback-only bind.
HOST=0.0.0.0

# Path to the SQLite database file
DATABASE_PATH=./data/gateway.db

# When set to "1", swaps the real Claude Subprocess for a stub that returns
# a canned response. Used by the integration test harness.
CLAUDE_SUBPROCESS_STUB=0

# Admin Console credentials
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me

# Secret used to sign Admin Console session cookies. Optional — falls back to
# ADMIN_PASSWORD if unset.
ADMIN_SECRET=
